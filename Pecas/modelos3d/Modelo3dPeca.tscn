[gd_scene format=3 uid="uid://eq83thkb3b8s"]

[sub_resource type="GDScript" id="GDScript_iip8x"]
script/source = "@tool
extends Node3D

@export var TorsoBase: String:
	set(value):
		TorsoBase = value
		criar_torso()

func criar_torso():
	for crianca in get_children():
		crianca.queue_free()
	
	if ResourceLoader.exists(TorsoBase):
		print(\"torso_valido\")
		
		var modelo_torso := load(TorsoBase)
		
		var instancia_torso = modelo_torso.instantiate()
		
		add_child(instancia_torso)
	
	else:
		print(\"torso_invalido\")
	
	pass
"

[node name="Modelo3dPeca" type="Node3D" unique_id=1310396139]
script = SubResource("GDScript_iip8x")
